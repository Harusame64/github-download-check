<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GitHubDownloadCheck.ViewModels"
        xmlns:models="using:GitHubDownloadCheck.Models"
        xmlns:views="using:GitHubDownloadCheck.Views"
        x:Class="GitHubDownloadCheck.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="GitHub Download Check"
        Width="1100" Height="720"
        MinWidth="800" MinHeight="500">

  <Window.Styles>
    <Style Selector="Border.card">
      <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundAltHighBrush}"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="16"/>
      <Setter Property="BoxShadow" Value="0 1 4 0 #18000000"/>
    </Style>
    <Style Selector="Button.accent">
      <Setter Property="Background" Value="{DynamicResource SystemAccentColor}"/>
      <Setter Property="Foreground" Value="White"/>
    </Style>
    <Style Selector="ListBoxItem">
      <Setter Property="CornerRadius" Value="6"/>
    </Style>
  </Window.Styles>

  <Grid ColumnDefinitions="220,*">

    <!-- Sidebar -->
    <Border Grid.Column="0" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            BorderThickness="0,0,1,0">
      <DockPanel>

        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Margin="12,16,12,8" Spacing="4">
          <TextBlock Text="GitHub Download Check" FontWeight="Bold" FontSize="14" TextWrapping="Wrap"/>
          <TextBlock Text="リリース ダウンロード分析" FontSize="11" Opacity="0.6"/>
        </StackPanel>

        <!-- Settings Button -->
        <Button DockPanel.Dock="Bottom" Content="⚙ 設定" Command="{Binding OpenSettingsCommand}"
                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                Margin="8,4,8,12" Padding="10,8"/>

        <!-- Repository List -->
        <StackPanel DockPanel.Dock="Top" Margin="8,4" Spacing="2">
          <TextBlock Text="リポジトリ" FontSize="11" Opacity="0.5" Margin="4,0,0,4" FontWeight="Medium"/>
          <ListBox ItemsSource="{Binding Repositories}"
                   SelectedItem="{Binding DashboardViewModel.SelectedRepository}"
                   Background="Transparent" BorderThickness="0">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="models:RepositoryEntry">
                <StackPanel Spacing="1">
                  <TextBlock Text="{Binding Label}" TextTrimming="CharacterEllipsis" FontSize="13"/>
                  <TextBlock Text="{Binding FullName}" FontSize="10" Opacity="0.5" TextTrimming="CharacterEllipsis"
                             IsVisible="{Binding DisplayName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
          <TextBlock Text="設定からリポジトリを追加してください"
                     Opacity="0.4" FontSize="11" TextWrapping="Wrap" Margin="4,8"
                     IsVisible="{Binding !Repositories.Count}"/>
        </StackPanel>

      </DockPanel>
    </Border>

    <!-- Main Content Area -->
    <Grid Grid.Column="1" RowDefinitions="Auto,*">

      <!-- Top Bar -->
      <Border Grid.Row="0" Padding="16,12"
              BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
              BorderThickness="0,0,0,1">
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0" Spacing="2">
            <TextBlock Text="{Binding DashboardViewModel.SelectedRepository.Label}"
                       FontWeight="SemiBold" FontSize="16"
                       IsVisible="{Binding DashboardViewModel.SelectedRepository, Converter={x:Static ObjectConverters.IsNotNull}}"/>
            <TextBlock Text="{Binding DashboardViewModel.SelectedRepository.FullName}"
                       FontSize="11" Opacity="0.5"
                       IsVisible="{Binding DashboardViewModel.SelectedRepository.DisplayName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
            <TextBlock Text="設定"
                       FontWeight="SemiBold" FontSize="16"
                       IsVisible="{Binding IsSettingsOpen}"/>
          </StackPanel>
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
            <Button Content="↺ 再取得"
                    Command="{Binding DashboardViewModel.FetchCommand}"
                    IsVisible="{Binding !IsSettingsOpen}"/>
            <Button Content="✕ 閉じる"
                    Command="{Binding CloseSettingsCommand}"
                    IsVisible="{Binding IsSettingsOpen}"/>
          </StackPanel>
        </Grid>
      </Border>

      <!-- View Content -->
      <ContentControl Grid.Row="1" Content="{Binding CurrentView}">
        <ContentControl.DataTemplates>
          <DataTemplate DataType="vm:DashboardViewModel">
            <views:DashboardView/>
          </DataTemplate>
          <DataTemplate DataType="vm:SettingsViewModel">
            <views:SettingsView/>
          </DataTemplate>
        </ContentControl.DataTemplates>
      </ContentControl>

    </Grid>
  </Grid>
</Window>
